# Per-service env vars. The gateway loads the parent repo's .env at compose
# time, so any vars referenced from compose.fragment.yml as ${NAME_FOO} must
# be present there.
#
# weave reads:
#   NEO4J_URI, NEO4J_USER, NEO4J_PASSWORD     - shared with neo4j service
#   OPENAI_API_KEY                            - shared
#   WEAVE_INTERNAL_TOKEN                      - shared secret for callers
#   WEAVE_OPENAI_MODEL                        - optional, default gpt-4o-mini
#   WEAVE_WATCHER_INTERVAL                    - optional, default 60s
#   WEAVE_WORKER_INTERVAL                     - optional, default 30s
#   WEAVE_WATCHER_BATCH                       - optional, default 10
#   WEAVE_WORKER_BATCH                        - optional, default 25
#   WEAVE_WATCHER_PATTERN_COOLDOWN_SEC        - optional, default 3600
#   WEAVE_SYNTHESIS_WORKER_ENABLED            - optional, default false
#
# All values live in the gateway repo's .env (local) or GH Actions Secrets
# (production). This file is documentation only.
